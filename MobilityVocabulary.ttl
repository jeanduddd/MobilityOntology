### Indicator Vocabulary

:IndicatorsScheme a skos:ConceptScheme;
    skos:prefLabel "Global indicator vocabulary"@en .

#Territorial Indicators

:TerritorialIndicatorsCollection a skos:Collection ;
    skos:inScheme :IndicatorsScheme ;
    skos:member :PresenceOfMovers, :PresenceOfMoversPerActivity, :ActivityShare, :PresenceDensity, :FluctuationRate, :PresenceFluctuation, :Attractiveness, :MobilityRate, :AttributeShare ;
    skos:prefLabel "Territorial indicators collection"@en ;
    skos:altLabel ""@en ;
    skos:hiddenLabel ""@en .

:PresenceOfMovers a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence of movers"@en ;
    skos:altLabel ""@en .

:PresenceOfMoversPerActivity a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence of movers per activity"@en ;
    skos:altLabel ""@en .

:ActivityShare a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Activity share"@en ;
    skos:altLabel ""@en .

:PresenceDensity a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
