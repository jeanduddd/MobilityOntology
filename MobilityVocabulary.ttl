### Indicator Vocabulary

mvdth:IndicatorsScheme a skos:ConceptScheme;
    skos:definition ""@en;
    skos:prefLabel "Global indicator vocabulary"@en .

#Territorial Indicators

mvdth:TerritorialIndicatorsCollection a skos:Collection ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition "A collection grouping every concepts related to territorial indicators"@en;
    skos:member mvdth:PresenceOfMovers, mvdth:PresenceOfMoversPerActivity, mvdth:ActivityShare, mvdth:PresenceDensity, mvdth:FluctuationRate, mvdth:PresenceFluctuation, mvdth:Attractiveness, mvdth:MobilityRate, mvdth:AttributeShare ;
    skos:prefLabel "Territorial indicators collection"@en .

mvdth:Presence a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence of movers"@en ;
    skos:altLabel ""@en .

mvdth:PresenceByPurpose a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence of movers per activity"@en ;
    skos:altLabel ""@en .

