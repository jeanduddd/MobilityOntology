@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix mvdth: <http://ns.inria.fr/movida/thesaurus> .

mvdth: a skos:ConceptScheme ;
    rdfs:label "Mobility Ontology Vocabulary" ;
    rdfs:comment "SKOS vocabulary for territorial mobility" ;
    owl:versionInfo "1.0" ;
    owl:imports mvdo: .

### Theme Vocabulary

mvdth:ThemeScheme a skos:ConceptScheme;
    skos:hasTopConcept mvdth:TripPurpose, mvdth:TransportationMode ;
    skos:definition "Global concept scheme englobing every concepts and collections that describe objects and spatial events, such as transportation mode or trip purposes"@en ;
    skos:prefLabel "Global theme vocabulary"@en .

#Trip Purpose Theme

mvdth:TripPurpose a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme;
    skos:topConceptOf mvdth:ThemeScheme ;
    skos:definition "Parent concept of every concepts related to the main reason for making a trip"@en ;
    skos:prefLabel "Trip purpose"@en .

mvdth:Work a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TripPurpose ;
    skos:definition "Trip motivated by professional activities or employment"@en ;
    skos:prefLabel "Work"@en ;
    skos:altLabel "Job"@en, "Employment"@en, "Working"@en .

mvdth:Home a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TripPurpose ;
    skos:definition "Trip motivated by returning to the place of residence"@en ;
    skos:prefLabel "Home"@en ;
    skos:altLabel "Residence"@en, "House"@en, "Return home"@en .
    
mvdth:Studying a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TripPurpose ;
    skos:definition "Trip motivated by attending education place such as school or universities"@en ;
    skos:prefLabel "Studying"@en ;
    skos:altLabel "Studies"@en, "School"@en, "Education"@en.

mvdth:Shopping a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TripPurpose ;
    skos:definition "Trip motivated by the purchase of goods or groceries in retail environments"@en ;
    skos:prefLabel "Shopping"@en ;
    skos:altLabel "Purchase"@en, "Purchasing"@en, "To shop"@en .

mvdth:Leisure a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TripPurpose ;
    skos:definition "Trip motivated by doing a free-time, recreational activity"@en ;
    skos:prefLabel "Leisure"@en ;
    skos:altLabel "Activity"@en, "Recreation"@en, "Free time"@en .

mvdth:OtherTripPurpose a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TripPurpose ;
    skos:definition "Trip motivated by reasons that do not fall into the primary categories, such as escorting others."@en ;
    skos:prefLabel "Other Trip Purpose"@en ;
    skos:altLabel "Other reasons"@en, "Other purpose"@en .

#Work subpurposes
mvdth:WorkAtUsualPlace a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Work ;
    skos:definition "Trip motivated by professional activity to the person's declared or usual workplace"@en ;
    skos:prefLabel "Work at usual place"@en ;
    skos:altLabel "Primary workspace"@en, "Declared workspace"@en, "Usual workspace" .

mvdth:WorkAtAnotherPlace a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Work ;
    skos:definition "Trip motivated by professional activity to a location other than the person's declared or usual workplace"@en ;
    skos:prefLabel "Work at another place"@en ;
    skos:altLabel "Unusual workspace"@en, "Other workspace"@en .

mvdth:Jobseeker a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Work ;
    skos:definition "Trip motivated by the search of an employment, such as job interviews or visiting employment agencies"@en ;
    skos:prefLabel "Jobseeker"@en ;
    skos:altLabel "Job interview"@en, "Job search"@en, "Visit employment agency" .

mvdth:ProfessionalTour a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Work ;
    skos:definition "Trip made as a part of the job, outside of the usual workplace, such as deliveries or meetings"@en ;
    skos:prefLabel "Professional tour"@en ;
    skos:altLabel "Business meeting"@en, "Business trip"@en, "Work outside usual place"@en .

#Home subpurposes
mvdth:MainResidence a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Home ;
    skos:definition "Trip motivated by the goal of returning to the main place of residence"@en ;
    skos:prefLabel "Main residence"@en ;
    skos:altLabel "Principal residence"@en, "Primary residence"@en, "Main home"@en, "Principal home"@en .

mvdth:OtherResidence a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Home ;
    skos:definition "Trip motivated by the goal of returning to a place of residence other than the person's main place of residence"@en ;
    skos:prefLabel "Other residence"@en ;
    skos:altLabel "Second home"@en, "Secondary residence"@en, "Second residence"@en, "Friend's residence"@en, "Friend's home"@en, "Residence of the parents"@en, "Parents' home"@en .

#Leisure subpurposes
mvdth:EatingOut a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Leisure ;
    skos:definition "Trip motivated by the goal of consumming food or drinks outside the person's place of residence"@en ;
    skos:prefLabel "Eating out"@en ;
    skos:altLabel "Dining out"@en, "Eating outiside"@en, "Dining outside"@en, "Restaurant"@en .

mvdth:SocialVisit a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Leisure ;
    skos:definition "Trip motivated by socializing, visiting a person such as friends or relatives"@en ;
    skos:prefLabel "Social visit"@en ;
    skos:altLabel "Visit parent"@en, "Visit friend"@en, "Socializing"@en, "Visit family"@en, "Visiting relatives"@en .

mvdth:SportsCultureAssociation a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Leisure ;
    skos:definition "Trip motivated by doing specific recreational activities including physical exercises, cultural events, or community and club activities"@en ;
    skos:prefLabel "Sports culture association"@en ;
    skos:altLabel "Sports"@en, "Associative life"@en, "Culture"@en, "Association"@en, "Physical exercice"@en, "Cultural events"@en, "Community activities"@en .

#Shopping subpurposes
mvdth:LargeRetailShopping a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Shopping ;
    skos:definition "Trip motivated by purchasing goods in a large retail store, such as supermarkets"@en ;
    skos:prefLabel "Large retail shopping"@en ;
    skos:altLabel "Supermarket"@en, "Hypermarket"@en, "Shopping mall"@en, "Shopping center"@en .

mvdth:SmallMediumRetailShopping a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Shopping ;
    skos:definition "Trip motivated by purchasing goods in a small or medium retail store"@en ;
    skos:prefLabel "Small medium retail shopping"@en ;
    skos:altLabel "Small shop"@en, "Local shop"@en, "Convenience store"@en .

mvdth:MarketShopping a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Shopping ;
    skos:definition "Trip motivated by purchasing goods at open-air, street, or covered market"@en ;
    skos:prefLabel "Market shopping"@en ;
    skos:altLabel "Open-air market"@en, "Street market"@en, "Farmer's market"@en, "Flea market"@en .

mvdth:ShoppingMallMultiPurpose a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Shopping ;
    skos:definition "Trip to a shopping mall motivated my multiple reasons, combining shopping and leisure such as socializing or eating out"@en ;
    skos:prefLabel "Shopping mall multi purpose"@en ;
    skos:altLabel "Mall hangout"@en, "Shopping and entertainment"@en .

#Studying subpurposes
mvdth:UsualPrimaryEducation a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending one's usual primary or elementary education institution"@en ;
    skos:prefLabel "Usual primary education"@en ;
    skos:altLabel "Usual elementary education"@en, "Usual basic education"@en, "Usual primary school"@en .

mvdth:UsualMiddleSchool a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending one's usual intermediate school or lower secondary education institution"@en ;
    skos:prefLabel "Usual middle school"@en ;
    skos:altLabel "Usual intermediate school"@en, "Usual senior public school"@en, "Usual junior high school"@en, "Usual junior secondary school"@en ,"Usual lower secondary school"@en .

mvdth:UsualHighSchool a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending one's usual high school education institution"@en ;
    skos:prefLabel "Usual high school"@en ;
    skos:altLabel "Usual senior high school"@en, "Usual upper secondary school"@en, "Usual senior secondary school"@en, "Usual secondary college"@en .

mvdth:UsualHigherEducation a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending one's usual higher education institution"@en ;
    skos:prefLabel "Usual higher education"@en ;
    skos:altLabel "Usual university"@en, "Usual college"@en, "Usual tertiary education"@en, "Usual higher education institution"@en .

mvdth:OtherPrimaryEducation a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending a primary or elementary education institution other than the person's usual one"@en ;
    skos:prefLabel "Other primary education"@en ;
    skos:altLabel "Other elementary education"@en, "Other basic education"@en, "Other primary school"@en .

mvdth:OtherMiddleSchool a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending a intermediate school or lower secondary education institution other than the person's usual one"@en ;
    skos:prefLabel "Other middle school"@en ;
    skos:altLabel "Other intermediate school"@en, "Other senior public school"@en, "Other junior high school"@en, "Other junior secondary school"@en ,"Other lower secondary school"@en .

mvdth:OtherHighSchool a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending a high school education institution other than the person's usual one"@en ;
    skos:prefLabel "Other high school"@en ;
    skos:altLabel "Other senior high school"@en, "Other upper secondary school"@en, "Other senior secondary school"@en, "Other secondary college"@en .

mvdth:OtherHigherEducation a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Studying ;
    skos:definition "Trip motivated by attending a higher education institution other than the person's usual one"@en ;
    skos:prefLabel "Other higher education"@en ;
    skos:altLabel "Other university"@en, "Other college"@en, "Other tertiary education"@en, "Other higher education institution"@en .

#Other subpurposes
mvdth:Childcare a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by bringing or picking-up a child from a daycare or nursery"@en ;
    skos:prefLabel "Childcare"@en ;
    skos:altLabel "Daycare"@en, "Nursery"@en, "Childminder"@en .

mvdth:Healthcare a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by receiving medical care or visiting a healthcare facility"@en ;
    skos:prefLabel "Healthcare"@en ;
    skos:altLabel "Medical appointment"@en, "Hospital"@en , "Doctor visit"@en, "Medical reasons"@en .

mvdth:AdministrativeProcedures a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by doing administrative formalities or visiting government offices"@en ;
    skos:prefLabel "Administrative procedures"@en ;
    skos:altLabel "Administrative actions"@en, "Administrative processes"@en, "Administrative formalities"@en, "Bureaucratic procedures"@en .

mvdth:StrollingAndWindowShopping a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by walking, strolling or observing shop windows for recreational purpose, without the intention of bying goods"@en ;
    skos:prefLabel "Strolling and window shopping"@en ;
    skos:altLabel "Strolling"@en, "Window shopping"@en, "Taking a walk"@en .

mvdth:AccompanyPersonPresent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by escorting another person at a specific destination."@en ;
    skos:prefLabel "Accompany person present"@en ;
    skos:altLabel "Traveling to drop-off"@en, "Escorting"@en .

mvdth:FetchPersonPresent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by leaving a pick up destination with the person who has been fetched"@en ;
    skos:prefLabel "Fetch person present"@en ;
    skos:altLabel "Returning from pick-up"@en .

mvdth:AccompanyPersonAbsent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by leaving a destination after having escorted and dropped off a person"@en ;
    skos:prefLabel "Accompany person absent"@en ;
    skos:altLabel "Returning from drop-off"@en, "Returning after escorting"@en .

mvdth:FetchPersonAbsent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by traveling to a destination to pick up a person"@en ;
    skos:prefLabel "Fetch person absent"@en ;
    skos:altLabel "Traveling to pick-up"@en .

mvdth:TransitDropOffPresent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by escorting another person at a transit station"@en ;
    skos:prefLabel "Transit drop off present"@en ;
    skos:altLabel "Traveling to transit station for drop-off"@en .

mvdth:TransitPickUpPresent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by leaving a transit station with the person who has been fetched"@en ;
    skos:prefLabel "Transit pick up present"@en ;
    skos:altLabel "Returning from transit station with fetched person"@en .

mvdth:TransitDropOffAbsent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by leaving a transit station after having escorted and dropped off a person"@en ;
    skos:prefLabel "Transit drop off absent"@en ;
    skos:altLabel "Returning from transit station after drop-off"@en .

mvdth:TransitPickUpAbsent a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by traveling to a transit station to pick up a person"@en ;
    skos:prefLabel "Transit pick up absent"@en ;
    skos:altLabel "Traveling to transit station for pick-up"@en .

mvdth:OtherPurposeNotListed a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTripPurpose ;
    skos:definition "Trip motivated by a reason that does not fit in the other categories"@en ;
    skos:prefLabel "Other purpose not listed"@en ;
    skos:altLabel "Other specific reason"@en, "Uncategorized purpose"@en .

#Transportation Mode Theme

mvdth:TransportationMode a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme;
    skos:topConceptOf mvdth:ThemeScheme ;
    skos:definition "Parent concept of every concepts related to any kind of vehicle or methode used for a trip"@en ;
    skos:prefLabel "Transportation mode"@en .

mvdth:Walk a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TransportationMode ;
    skos:definition "Displacement made on foot"@en ;
    skos:prefLabel "Walk"@en ;
    skos:altLabel "Walking"@en .

mvdth:Bike a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TransportationMode ;
    skos:definition "Unmotorized or electrically assisted pedal-driven vehicle, most of the time on two wheels"@en ;
    skos:prefLabel "Bike"@en ;
    skos:altLabel "Bicycle"@en, "Cycling"@en .

mvdth:Car a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TransportationMode ;
    skos:definition "Motorized wheeled vehicle designed to transport a small amount of passengers on roads"@en ;
    skos:prefLabel "Car"@en ;
    skos:altLabel "Automobile"@en, "SUV"@en, "4x4"@en .

mvdth:PublicTransportation a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TransportationMode ;
    skos:definition "Shared transportation mode used as a passenger, available to everyone and working on lines and schedules, with a high passenger capacity, such as trains, trams, buses"@en ;
    skos:prefLabel "Public Transportation"@en ;
    skos:altLabel "PTS"@en, "Public Transport"@en .

mvdth:OtherTransportationMode a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:TransportationMode ;
    skos:definition "Any vehicle that do not fall into the primary categories, such as cablecars or airplanes"@en ;
    skos:prefLabel "Other Transportation Mode"@en ;
    skos:altLabel "Other transport mode"@en, "Other mode"@en .

#Car submodes
mvdth:PrivateCar a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Car ;
    skos:definition "Vehicle mainly used for personal purposes, without fare-paying passengers and is at the disposal of the household"@en ;
    skos:prefLabel "Private car"@en ;
    skos:altLabel "Personal car"@en .

mvdth:TaxiPassenger a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Car ;
    skos:definition "Transport mode where the individual travels as a paying passenger in a car driven by a professional driver"@en ;
    skos:prefLabel "Taxi passenger"@en ;
    skos:altLabel "Cab"@en, "Taxi"@en, "Uber"@en .

#Public transport submodes
mvdth:CityBus a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:PublicTransport ;
    skos:definition "Large motorized vehicle whose route stays inside the same urban area"@en ;
    skos:prefLabel "City bus"@en ;
    skos:altLabel "Local bus"@en, "Public bus"@en .

mvdth:Tramway a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:PublicTransport ;
    skos:definition "Rail vehicle whose route stays inside the same urban area"@en ;
    skos:prefLabel "Tramway"@en ;
    skos:altLabel "Trolley"@en, "Tram"@en, "Streetcar"@en .

mvdth:IntercityBus a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:PublicTransport ;
    skos:definition "Large motorized vehicle with luggage holds, designed for interurban, regional or long-distance passenger travel, requiring passengers to be seated"@en ;
    skos:prefLabel "Intercity bus"@en ;
    skos:altLabel "Coach"@en, "Long-distance bus"@en  .

mvdth:Train a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:PublicTransport ;
    skos:definition "Rail vehicle, designed for interurban, regional or long-distance passenger travel"@en ;
    skos:prefLabel "Train"@en ;
    skos:altLabel "Regional train"@en, "Intercity train"@en, "Railway"@en .

#Other transportation submodes
mvdth:LightMotorizedTwoWheeler a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Motorized two-wheeled vehicle with engine displacement lower than 50 cm³"@en ;
    skos:prefLabel "Light motorized two wheeler"@en ;
    skos:altLabel "Two wheels < 50 cm³"@en .

mvdth:MotorizedTwoWheeler a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Motorized two-wheeled vehicle with engine displacement greater than or equal to 50 cm³"@en ;
    skos:prefLabel "Motorized two wheeler"@en ;
    skos:altLabel "Two wheels ≥ 50 cm³"@en .

mvdth:Wheelchair a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Wheeled mobility device that can be manual or eletrically powered, designed to help people who cannot walk or have difficulty walking."@en ;
    skos:prefLabel "Wheelchair"@en ;
    skos:altLabel "Manual wheelchair"@en, "Motorized wheelchair"@en, "Electric wheelchair"@en .

mvdth:CableCar a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Cabin suspended between cables, mostly used to cross difficult terrains such as mountains"@en ;
    skos:prefLabel "Cable car"@en ;
    skos:altLabel "Manual wheelchair"@en, "Motorized wheelchair"@en .

mvdth:Airplane a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Powered flying vehicle, designed for long-distance domestic or international travel through the air"@en ;
    skos:prefLabel "Airplane"@en ;
    skos:altLabel "Plane"@en, "Aircraft"@en, "Aeroplane"@en, "Air travel"@en, "Flight"@en .

mvdth:SchoolTransportation a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Any kind of transportation mode used to pick up people and take them to their place of study"@en ;
    skos:prefLabel "School transportation"@en ;
    skos:altLabel "School bus"@en, "Student transportation"@en .

mvdth:WaterTransportation a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Any kind of vehicle design to carry passengers on water, whether it is on a river, a lake or a sea"@en ;
    skos:prefLabel "Water transportation"@en ;
    skos:altLabel "Boat"@en, "Ship"@en, "Ferry"@en, "Water taxi"@en, "Hovercraft"@en, "Sailboat"@en .

mvdth:EmployerSponsoredTransportation a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Any kind of transportation mode provided by an employer for the transportation of its employees"@en ;
    skos:prefLabel "Employer sponsored transportation"@en ;
    skos:altLabel "Company car"@en, "Employer shuttle"@en .

mvdth:TruckVan a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Large motorized vehicle with only a few passenger seats, designed to carry goods, equipment or materials, ranging from light vans to heavy trucks. Can be used for professional or personal reasons"@en ;
    skos:prefLabel "Truck van"@en ;
    skos:altLabel "Truck"@en, "Van"@en, "Delivery van"@en, "Commercial vehicle"@en .

mvdth:PersonalMobilityDevice a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Any kind of small wheeled device, either human-powered or electrically powered, designed to carry a single person"@en ;
    skos:prefLabel "Personal mobility device"@en ;
    skos:altLabel "Skateboard"@en, "Scooter"@en, "Electric scooter"@en, "Rollerblade"@en, "Roller skate"@en, "Segway"@en .

mvdth:VariousOtherModes a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:OtherTransportationMode ;
    skos:definition "Any vehicle that do not fall into the predefined categories, such as agricultural, construction or not listed vehicles"@en ;
    skos:prefLabel "Various other modes"@en ;
    skos:altLabel "Tractor"@en, "Agricultural vehicle"@en, "Unspecified mode"@en .

### Indicator Vocabulary

mvdth:IndicatorsScheme a skos:ConceptScheme;
    skos:definition "Global concept scheme englobing every concepts and collections that describe statistical indicators"@en;
    skos:prefLabel "Global indicator vocabulary"@en .

#Territorial Indicators

mvdth:TerritorialIndicatorsCollection a skos:Collection ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition "A collection grouping every concepts related to territorial indicators"@en;
    skos:member mvdth:Presence, mvdth:Fluctuation, mvdth:Attractiveness ;
    skos:prefLabel "Territorial indicators collection"@en .

mvdth:Presence a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition "Territorial indicator measuring the count of different movers that visited a spatial location or trips directed towards a spatial location at a specific time unit"@en ;
    skos:prefLabel "Presence"@en .

mvdth:Fluctuation a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition "Territorial indicator measuring the difference between the count of different movers that visited a spatial location at a specific time unit and the location\'s estimated population size"@en ;
    skos:prefLabel "Fluctuation"@en .

mvdth:Attractiveness a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition "Territorial indicator measuring the aggregate number of movers that visited a spatial location over 24 hours divided by the location\'s population size, adjusted by the global value of this same ratio for the whole region"@en ;
    skos:prefLabel "Attractiveness"@en .