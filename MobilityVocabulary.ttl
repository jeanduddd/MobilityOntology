### Indicator Vocabulary

mvdth:IndicatorsScheme a skos:ConceptScheme;
    rdfs:comment ""@en;
    skos:prefLabel "Global indicator vocabulary"@en .

#Territorial Indicators

mvdth:TerritorialIndicatorsCollection a skos:Collection ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:member mvdth:PresenceOfMovers, mvdth:PresenceOfMoversPerActivity, mvdth:ActivityShare, mvdth:PresenceDensity, mvdth:FluctuationRate, mvdth:PresenceFluctuation, mvdth:Attractiveness, mvdth:MobilityRate, mvdth:AttributeShare ;
    skos:prefLabel "Territorial indicators collection"@en ;
    skos:altLabel ""@en ;
    skos:hiddenLabel ""@en .

mvdth:Presence a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence of movers"@en ;
    skos:altLabel ""@en .

mvdth:PresenceByPurpose a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence of movers per activity"@en ;
    skos:altLabel ""@en .

mvdth:ActivityShare a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Activity share"@en ;
    skos:altLabel ""@en .

mvdth:PresenceDensity a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence density"@en ;
    skos:altLabel ""@en .

mvdth:FluctuationRate a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Fluctuation rate"@en ;
    skos:altLabel ""@en .

mvdth:PresenceFluctuation a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence fluctuation"@en ;
    skos:altLabel ""@en .

mvdth:Attractiveness a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Attractiveness"@en ;
    skos:altLabel ""@en .

mvdth:MobilityRate a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Mobility rate"@en ;
    skos:altLabel ""@en .

mvdth:AttributeShare a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Attribute share"@en ;
    skos:altLabel ""@en .

