    skos:definition ""@en ;
    skos:prefLabel "Presence fluctuation"@en ;
    skos:altLabel ""@en .

mvdth:Attractiveness a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Attractiveness"@en ;
    skos:altLabel ""@en .

mvdth:MobilityRate a skos:Concept, mvdo:TerritoryIndicator ;
    skos:inScheme mvdth:IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Mobility rate"@en ;
    skos:altLabel ""@en .

mvdth:AttributeShare a skos:Concept, mvdo:TerritoryIndicator ;
