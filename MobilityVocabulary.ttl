    skos:prefLabel "Presence density"@en ;
    skos:altLabel ""@en .

:FluctuationRate a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Fluctuation rate"@en ;
    skos:altLabel ""@en .

:PresenceFluctuation a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Presence fluctuation"@en ;
    skos:altLabel ""@en .

:Attractiveness a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Attractiveness"@en ;
    skos:altLabel ""@en .

:MobilityRate a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Mobility rate"@en ;
    skos:altLabel ""@en .

:AttributeShare a skos:Concept, :TerritoryIndicator ;
    skos:inScheme :IndicatorsScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Attribute share"@en ;
    skos:altLabel ""@en .

