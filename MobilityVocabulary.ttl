#Transportation Mode Theme

:TransportationModeCollection a skos:Collection ;
    skos:inScheme :ThemeScheme ;
    skos:member :Walk, :Bike, :Car, :PublicTransport, :OtherTransportationMode ;
    skos:prefLabel "Transportation mode collection"@en .

:Walk a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Walk"@en ;
    skos:altLabel ""@en .

:Bike a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Bike"@en ;
    skos:altLabel ""@en .

:Car a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Car"@en ;
    skos:altLabel ""@en .

:PublicTransport a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Public Transport"@en ;
    skos:altLabel ""@en .

:OtherTransportationMode a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Other Transportation Mode"@en ;
    skos:altLabel ""@en .

