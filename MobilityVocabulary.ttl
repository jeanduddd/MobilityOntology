@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix mvdth: <http://ns.inria.fr/movida/thesaurus> .

mvdth: a skos:ConceptScheme ;
    rdfs:label "Mobility Ontology Vocabulary" ;
    rdfs:comment "SKOS vocabulary for territorial mobility" ;
    owl:versionInfo "1.0" ;
    owl:imports mvdo: .

### Theme Vocabulary

mvdth:ThemeScheme a skos:ConceptScheme;
    rdfs:comment ""@en ;
    skos:prefLabel "Global theme vocabulary"@en .

#Trip Purpose Theme

mvdth:TripPurposeCollection a skos:Collection ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:member :Work, mvdth:Home, mvdth:Studying, mvdth:Shopping, mvdth:Leisure, mvdth:OtherTripPurpose ;
    skos:prefLabel "Trip purpose collection"@en ;
    skos:definition ""@en .

mvdth:Work a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Work"@en ;
    skos:altLabel ""@en .

mvdth:Home a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Home"@en ;
    skos:altLabel ""@en .
    
mvdth:Studying a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Studying"@en ;
    skos:altLabel ""@en .

mvdth:Shopping a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Shopping"@en ;
    skos:altLabel ""@en .

mvdth:Leisure a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Leisure"@en ;
    skos:altLabel ""@en .

mvdth:OtherTripPurpose a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Other Trip Purpose"@en ;
    skos:altLabel ""@en .


#Work subpurpose
mvdth:DeclaredPlaceOfWork a skos:Concept, mvdo:TripPurpose ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel ""@en ;
    skos:altLabel ""@en .

