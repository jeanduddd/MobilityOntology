#Transportation Mode Theme

mvdth:TransportationModeCollection a skos:Collection ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition "A collection grouping every concepts related to any kind of vehicule or methode used for a trip"@en ;
    skos:member mvdth:Walk, mvdth:Bike, mvdth:Car, mvdth:PublicTransport, mvdth:OtherTransportationMode ;
    skos:prefLabel "Transportation mode collection"@en .

mvdth:Walk a skos:Concept, mvdo:TransportationMode ;
