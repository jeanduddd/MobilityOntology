#Transportation Mode Theme

mvdth:TransportationModeCollection a skos:Collection ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:member mvdth:Walk, mvdth:Bike, mvdth:Car, mvdth:PublicTransport, mvdth:OtherTransportationMode ;
    skos:prefLabel "Transportation mode collection"@en .

mvdth:Walk a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Walk"@en ;
    skos:altLabel ""@en .

mvdth:Bike a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Bike"@en ;
    skos:altLabel ""@en .

mvdth:Car a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Car"@en ;
    skos:altLabel ""@en .

mvdth:PublicTransportation a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Public Transportation"@en ;
    skos:altLabel ""@en .

mvdth:OtherTransportationMode a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:definition ""@en ;
    skos:prefLabel "Other Transportation Mode"@en ;
    skos:altLabel ""@en .

#Car submodes
mvdth:PersonalVehiculeDriver a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Car ;
    skos:definition ""@en ;
    skos:prefLabel "personal vehicule driver"@en ;
    skos:altLabel ""@en .

mvdth:PersonalVehiculePassenger a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Car ;
    skos:definition ""@en ;
    skos:prefLabel "personal vehicule passenger"@en ;
    skos:altLabel ""@en .

mvdth:TaxiPassenger a skos:Concept, mvdo:TransportationMode ;
    skos:inScheme mvdth:ThemeScheme ;
    skos:broader mvdth:Car ;
    skos:definition ""@en ;
    skos:prefLabel "taxi passenger"@en ;
    skos:altLabel ""@en .

