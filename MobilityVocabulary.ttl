    skos:definition ""@en ;
    skos:prefLabel "two wheels < 50cm3"@en ;
    skos:altLabel ""@en .

:twoWheelsGreaterOrEqualTo50cm3 a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:broader :OtherTransportationMode ;
    skos:definition ""@en ;
    skos:prefLabel "two wheels ≥ 50cm3"@en ;
    skos:altLabel ""@en .

:Wheelchair a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:broader :OtherTransportationMode ;
    skos:definition ""@en ;
    skos:prefLabel "Wheelchair"@en ;
    skos:altLabel ""@en .

:CableCar a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:broader :OtherTransportationMode ;
    skos:definition ""@en ;
    skos:prefLabel "cable car"@en ;
    skos:altLabel ""@en .

:plane a skos:Concept, :TransportationMode ;
    skos:inScheme :ThemeScheme ;
    skos:broader :OtherTransportationMode ;
    skos:definition ""@en ;
    skos:prefLabel "plane"@en ;
    skos:altLabel ""@en .



