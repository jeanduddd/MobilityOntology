@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix geo:  <http://www.opengis.net/ont/geosparql#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix mvdo: <http://ns.inria.fr/movida/ontology#> .

mvdo: a owl:Ontology ;
    rdfs:label "Mobility Ontology" ;
    rdfs:comment "Representation of territorial mobility indicators" ;
    owl:versionInfo "1.0" .

### Indicators

# Indicator

# Use prov:wasDerivedFrom from PROV ontology to link the indicator to the indicator from which it was derived
mvdo:Indicator a owl:Class ;
    rdfs:subClassOf prov:Entity, sosa:ObservableProperty ;
    rdfs:label "Indicator"@en ;
    rdfs:comment "Indicators describe mobility measures throughout space, time, and theme dimensions. This class is further specialized to describe different types of indicators."@en .

#Territory Indicator

mvdo:TerritoryIndicator a owl:Class ;
    rdfs:subClassOf mvdo:Indicator ;
    rdfs:label "Territory indicator"@en ;
    rdfs:comment "Statistical indicator describing the usage of a spatial location, such as via the presence of individuals. Usually defined over multiple time intervals and described by thematic attributes such as performed activities."@en .

#Movement Indicator

mvdo:MovementIndicator a owl:Class ;
    rdfs:subClassOf mvdo:Indicator ;
    rdfs:label "Movement indicator"@en ;
    rdfs:comment "Statistical indicator describing the movement of entities, such as via trips or flows. Usually defined over multiple time intervals and described via thematic attributes, such as trip purposes and transportation modes."@en .

#Indicator properties

mvdo:hasIndicatorType a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range skos:Concept ;
    rdfs:label "has indicator type"@en ;
    rdfs:comment "Links an indicator to the conceptual type of indicator (e.g., presence, fluctuation, travel flows) it instantiates."@en .

mvdo:hasObject a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range mvdo:Object ;
    rdfs:label "has object" ;
    rdfs:comment "Links an indicator to the object of interest of the indicator, such as trips or movers."@en .

# Use quantitykind concepts from quantitykind vocabulary as range to indicate the method of calculation of the indicator
# ex : quantitykind:Count, quantitykind:DimensionlessRatio, quantitykind:AreaDensity...
mvdo:hasCalculationMethod a owl:ObjectProperty ;
    rdfs:subPropertyOf qudt:hasQuantityKind ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range mvdo:CalculationMethod ; # TODO: I could not find the SKOS for the calculation methods
    rdfs:label "has calculation method"@en ;
    rdfs:comment "Links an indicator to its calculation method."@en .

mvdo:hasTerritorialPartition a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range mvdo:TerritorialPartition ;
    rdfs:label "has territorial partition" ;
    rdfs:comment "Links an indicator to the territorial partition of reference for the indicator. This information is particularly usefull to describe indicators defined per spatial location."@en .

# TODO: the following prooperties have to be reviewed, a spatial granularity would be directly a territorial partition (e.g. the space is described via neighborhoods), while here we only want to indicate whether the space is aggregated or not. Same for time. I suggest to change these properties for a boolean one, eg.

mvdo:isAggregated a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (
            mvdo:Space
            mvdo:Time # TODO: this class should exist, see comment below
        )
    ] ;
    rdfs:range rdfs:Boolean ;
    rdfsl:label "is aggregated";
    rdfs:comment "Defines whether the space or time dimensions are aggregated, e.g., the indicator is defined over the whole territory or individual spatial locations."  .

# mvdo:hasSpatialGranularity a owl:DatatypeProperty ;
#     rdfs:domain mvdo:Indicator ;
#     rdfs:range rdfs:Literal ;
#     rdfs:label "has space aggregation" ;
#     rdfs:comment "Links an indicator with a string describing whether the space is aggregated or not (individual or aggregate)"@en .

# mvdo:hasTimeGranularity a owl:DatatypeProperty ;
#     rdfs:domain mvdo:Indicator ;
#     rdfs:range rdfs:Literal ;
#     rdfs:label "has time aggregation" ;
#     rdfs:comment "Links an indicator with a string describing whether the time is aggregated or not (individual or aggregated)"@en .

# TODO: rename this as mvdo:hasTheme ; and there the range is mvdo:Theme, which is instantiated as SKOS concepts
mvdo:hasThematicAttributeGranularity a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range skos:Concept ;
    rdfs:label "has thematic attribute" ;
    rdfs:comment "Links an indicator to the conceptual thematic attribute category it records. This property is used for presence indicator, to specify whether it's a global presence (no thematic attribute) or is disaggregated by a specific theme such as trip purpose for the presence per activity indicator"@en .

#Data Record

# Use sosa:hasSimpleResult from SOSA ontology to link a data record to its value
mvdo:DataRecord a owl:Class ;
    rdfs:subclassOf sosa:Observation ;
    rdfs:label "Data record" ;
    rdfs:comment "A data point representing the value of an indicador for a specific combination of the mobility dimensions."@en .

mvdo:isRecordOf a owl:ObjectProperty ;
    rdfs:subPropertyOf sosa:observedProperty ;
    rdfs:domain mvdo:DataRecord ;
    rdfs:range mvdo:Indicator ;
    rdfs:label "is record of" ;
    rdfs:comment "Links a data record to the corresponding indicator."@en .

mvdo:hasTransportationMode a owl:ObjectProperty ;
    rdfs:domain mvdo:DataRecord ;
    rdfs:range mvdo:TransportationMode ;
    rdfs:label "has transportation mode"@en ;
    rdfs:comment "Links a data record to a transportation mode for which it is calculated."@en .

mvdo:hasTripPurpose a owl:ObjectProperty ;
    rdfs:domain mvdo:DataRecord ;
    rdfs:range mvdo:TripPurpose ;
    rdfs:label "has trip purpose"@en ;
    rdfs:comment "Links a data record to a trip purpose for which it is calculated."@en .  

# Use time:hasBeginning from OWL Time to add a begin time instant to the time interval
# Use time:hasEnd from OWL Time to add an end time instant to the time interval
# Use time:inDateTime from OWL Time to link an time instant to a structured date time description

# Use time:hasDurationDescription from OWL Time to link a time interval to a structured duration description
# Use time:hasTemporalDuration from OWL time to link a time Interval to a Generalized Duration Description

# Use time:hasDuration from OWL Time to link a time interval to a Duration
# Use time:numericalDuration from OWL Time to link a Duration to its numerical value

# Use time:unitType from OWL Time to link a Duration or a General Date Time Description to its temporal unit / scale / granularity

# TODO: for the sake of consistency, I propose to create a class mvdo:Time which is a subclass of time:Interval. This way we can model the data according to the defined dimensions.

mvdo:Time a owl:Class ;
    rdfs:subClassOf time:Interval . # TODO: to be completed and used instead of time:Interval from here forward

mvdo:hasTimeInterval a owl:ObjectProperty ;
    rdfs:subPropertyOf sosa:phenomenonTime ;
    rdfs:domain mvdo:DataRecord ;
    rdfs:range time:Interval ;
    rdfs:label "has time"@en ;
    rdfs:comment "Links a data record to the temporal extent it was computed"@en .

#Spatial links properties

mvdo:hasSpatialLocation a owl:ObjectProperty ;
    rdfs:domain mvdo:DataRecord ;
    rdfs:range mvdo:Space ;
    rdfs:label "has spatial location"@en ;
    rdfs:comment "Links a data record to the associated spatial location."@en .

mvdo:hasOrigin a owl:ObjectProperty ;
    rdfs:subPropertyOf mvdo:hasSpatialLocation ;
    rdfs:domain mvdo:DataRecord ;
    rdfs:range mvdo:Space ;
    rdfs:label "has origin"@en ;
    rdfs:comment "Links a movement data record to a origin spatial location."@en .

mvdo:hasDestination a owl:ObjectProperty ;
    rdfs:subPropertyOf mvdo:hasSpatialLocation ;
    rdfs:domain mvdo:DataRecord ;
    rdfs:range mvdo:Space ;
    rdfs:label "has destination"@en ;
    rdfs:comment "Links a movement record to a destination spatial location."@en .

###Space

# Use geo:hasGeometry from GeoSPARQL ontology to link the geographic area to its geometry
# Use geo:hasMetricArea from GeoSPARQL ontology to link the geographic area to its area in m²
mvdo:Space a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Space"@en ;
    rdfs:comment "A class used to describe a spatial location."@en .

mvdo:isPartOf a owl:ObjectProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range mvdo:Space ;
    rdfs:label "is part of"@en ;
    rdfs:comment "Creates a hierarchy of spatial locations by linking a spatial location to another location that contains it."@en .

mvdo:hasID a owl:DatatypeProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range xsd:integer ;
    rdfs:label "has id"@en ;
    rdfs:comment "Links a spatial location to an identifier."@en .

mvdo:hasName a owl:DatatypeProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range rdfs:Literal ;
    rdfs:label "has name"@en ;
    rdfs:comment "Links a spatial location to a name."@en .

mvdo:hasPopulation a owl:DatatypeProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range xsd:integer ;
    rdfs:label "has population"@en ;
    rdfs:comment "Links a spatial location to the population that inhabitates it."@en .

### Object

mvdo:Object a owl:Class ;
    rdfs:label "Object"@en ;
    rdfs:comment "A physical or abstract entity that serves as the basis for calculating a territorial indicator, such as trips or movers."@en .

### Theme

mvdo:Theme a owl:Class ;
    rdfs:label "Theme"@en ;
    rdfs:comment "Describes objects according to socio-demographic aspects, activities and trip purposes, and transportation modes"@en .

mvdo:TripPurpose a owl:Class ;
    rdfs:subClassOf mvdo:Theme ;
    rdfs:label "Trip Purpose"@en ;
    rdfs:comment "Thematic attribute describing a trip in terms of reasons (e.g., leisure, work, etc.) for taken it."@en .

mvdo:TransportationMode a owl:Class ;
    rdfs:subClassOf mvdo:Theme ;
    rdfs:label "Transportation Mode"@en ;
    rdfs:comment "Thematic attribute describing a trip in terms of which transportation mode (e.g., car, bike, bus, etc.) was used to perform it."@en .

### Territorial partition

mvdo:TerritorialPartition a owl:Class ;
    rdfs:label "Territorial Partition"@en ;
    rdfs:comment "A class used to describe the spatial granularity, i.e. how the territory is partitioned into spatial locations."@en .

mvdo:hasPartitionID a owl:DatatypeProperty ;
    rdfs:domain mvdo:TerritorialPartition ;
    rdfs:range rdfs:Literal ;
    rdfs:label "has partition id"@en ;
    rdfs:comment "Defines the identifier of the territorial partition."@en .

mvdo:hasParts a owl:DatatypeProperty ;
    rdfs:domain mvdo:TerritorialPartition ;
    rdfs:range xsd:integer ;
    rdfs:label "has parts"@en ;
    rdfs:comment "Defines the number of spatial locations contained in the territorial partition."@en .

mvdo:containsSpace a owl:ObjectProperty ;
    rdfs:domain mvdo:TerritorialPartition ;
    rdfs:range mvdo:Space ;
    rdfs:label "contains space"@en ;
    rdfs:comment "Links the territorial partitiion to its spatial locations."@en .

### Calculation Method

# Use qudt:hasNumeratorPart from QUDT to link a quantity kind to the value of its numerator's formula. It can be anything such as a Literal or a String
# Use qudt:hasDenominatorPart from QUDT to link a quantity kind to the value of its denominator's formula. It can be anything such as a Literal or a String
# Use qudt:expression from QUDT to link a quantity kind to its one line formula. It can be anything such as a Literal or a String
mvdo:CalculationMethod a owl:Class ;
    rdfs:subclassOf qudt:QuantityKind ;
    rdfs:label "Calculation method"@en ;
    rdfs:comment "Mathematical method used to calculate an indicator, such as a count, a ratio or a density"@en .

# TODO: specific calculation methods to be defined as a SKOS, in a high-level but homogeneous manner.
