@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix mvdo: <http://ns.inria.fr/movida/ontology> .

mvdo: a owl:Ontology ;
    rdfs:label "Mobility Ontology" ;
    rdfs:comment "Representation of territorial mobility indicators" ;
    owl:versionInfo "1.0" .

### Indicators

# General Indicator

# Use prov:wasDerivedFrom from PROV ontology to link the indicator to the indicator from which it was derived
mvdo:Indicator a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Indicator"@en ;
    rdfs:comment "Superclass for every type of indicator"@en .

mvdo:hasTransportationMode a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range mvdo:TransportationMode ;
    rdfs:label "has transportation mode"@en ;
    rdfs:comment "Links an indicator to the thematic attribute of the transportation mode it has been computed with"@en .

mvdo:hasTripPurpose a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range mvdo:TripPurpose ;
    rdfs:label "has trip purpose"@en ;
    rdfs:comment "Links an indicator to the thematic attribute of the trip purpose it has been computed with"@en .  

mvdo:hasIndicatorType a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range skos:Concept ;
    rdfs:label "has indicator type"@en ;
    rdfs:comment "Links an indicator observation to the conceptual type of indicator it instantiates."@en .

mvdo:hasObject a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range mvdo:Object ;
    rdfs:label "has object" ;
    rdfs:comment "Links an indicator to the object counted to compute the territoral indicator, such as trips or movers"@en .

# Use time:hasBeginning from OWL Time to add a begin time instant to the time interval
# Use time:hasEnd from OWL Time to add an end time instant to the time interval
# Use time:inDateTime from OWL Time to link an time instant to a structured date time description

# Use time:hasDurationDescription from OWL Time to link a time interval to a structured duration description
# Use time:hasTemporalDuration from OWL time to link a time Interval to a Generalized Duration Description

# Use time:hasDuration from OWL Time to link a time interval to a Duration
# Use time:numericalDuration from OWL Time to link a Duration to its numerical value

# Use time:unitType from OWL Time to link a Duration or a General Date Time Description to its temporal unit / scale / granularity
mvdo:hasTimeInterval a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range time:Interval ;
    rdfs:label "has time"@en ;
    rdfs:comment "Links an indicator to the temporal extent it was computed"@en .

# Use qudt:hasNumeratorPart from QUDT to link a quantity to the value of its numerator. It can be anything such as a Literal or an integer
# Use qudt:hasDenominatorPart from QUDT to link a quantity to the value of its denominator. It can be anything such as a Literal or an integer
# Use qudt:value from QUDT to link a quantity to its decimal value
mvdo:hasRate a owl:ObjectProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range qudt:Quantity ;
    rdfs:label "has rate"@en ;
    rdfs:comment "Links an indicator describing a rate or a share to its corresponding ratio description"@en .

mvdo:hasCount a owl:DatatypeProperty ;
    rdfs:domain mvdo:Indicator ;
    rdfs:range xsd:decimal;
    rdfs:label "has count"@en ;
    rdfs:comment "Links an indicator describing a count to its corresponding value"@en .

#Territory Indicator

mvdo:TerritoryIndicator a owl:Class ;
    rdfs:subClassOf mvdo:Indicator ;
    rdfs:label "Territory indicator"@en ;
    rdfs:comment "Statistical indicator corresponding to the number of visitors in the location at a particular time unit"@en .

mvdo:hasSpatialLocation a owl:ObjectProperty ;
    rdfs:domain mvdo:TerritoryIndicator ;
    rdfs:range mvdo:Space ;
    rdfs:label "has spatial location"@en ;
    rdfs:comment "Links a territory indicator to the location it describes"@en .

#Travel Flow

mvdo:TravelFlow a owl:Class ;
    rdfs:subClassOf mvdo:Indicator ;
    rdfs:label "Travel flow"@en ;
    rdfs:comment "Statistical indicator corresponding to the flow magnitude between two locations"@en .

mvdo:hasOrigin a owl:ObjectProperty ;
    rdfs:domain mvdo:TravelFlow ;
    rdfs:range mvdo:Space ;
    rdfs:label "has origin"@en ;
    rdfs:comment "Links a flow to its origin"@en .

mvdo:hasDestination a owl:ObjectProperty ;
    rdfs:domain mvdo:TravelFlow ;
    rdfs:range mvdo:Space ;
    rdfs:label "has destination"@en ;
    rdfs:comment "Links a flow to its destination"@en .

### Object

mvdo:Object a owl:Class ;
    rdfs:label "Object"@en ;
    rdfs:comment "A physical or abstract entity that serves as the basis for calculating a territorial indicator, such as trips or movers"@en .

mvdo:Trips a owl:Class ;
    rdfs:subClassOf mvdo:Object ;
    rdfs:label "Trips"@en ;
    rdfs:comment "An abstract entity with an origin to a destination, whose destination count serves as the basis for calculating territorial indicators related to travel volume or mobility rates"@en .

mvdo:Movers a owl:Class ;
    rdfs:subClassOf mvdo:Object ;
    rdfs:label "Movers"@en ;
    rdfs:comment "A physical entity, whose count within a spatial location serves as the basis for calculating territorial indicators related to human presence, density, or fluctuation."@en .

### Theme

mvdo:Theme a owl:Class ;
    rdfs:label "Theme"@en ;
    rdfs:comment "Describes the objects and spatial events according to socio-demographic aspects, activities and trip purposes, and transportation modes"@en .

mvdo:TripPurpose a owl:Class ;
    rdfs:subClassOf mvdo:Theme ;
    rdfs:label "Trip Purpose"@en ;
    rdfs:comment "Thematic attribute that describes the main reason for making a trip"@en .

mvdo:TransportationMode a owl:Class ;
    rdfs:subClassOf mvdo:Theme ;
    rdfs:label "Transportation Mode"@en ;
    rdfs:comment "Thematic attribute that describes with which travel medium the trip is made"@en .


### Space

# Use geo:hasGeometry from GeoSPARQL ontology to link the geographic area to its geometry
# Use geo:hasMetricArea from GeoSPARQL ontology to link the geographic area to its area in m²
mvdo:Space a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Space"@en ;
    rdfs:comment "A class used to describe a spatial location"@en .

mvdo:isPartOf a owl:ObjectProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range mvdo:Space ;
    rdfs:label "is part of"@en ;
    rdfs:comment "Links a spatial location to the one that surrounds it"@en .

mvdo:hasTerritorialPartition a owl:ObjectProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range mvdo:TerritorialPartition ;
    rdfs:label "has territorial partition"@en ;
    rdfs:comment "Links a spatial location to the description of the territorial partition used for the indicator"@en .

mvdo:hasID a owl:DatatypeProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range xsd:integer ;
    rdfs:label "has id"@en ;
    rdfs:comment "Links a spatial location to its ID"@en .

mvdo:hasName a owl:DatatypeProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range rdfs:Literal ;
    rdfs:label "has name"@en ;
    rdfs:comment "Links a spatial location to its name"@en .

mvdo:hasPopulation a owl:DatatypeProperty ;
    rdfs:domain mvdo:Space ;
    rdfs:range xsd:integer ;
    rdfs:label "has population"@en ;
    rdfs:comment "Links a spatial location to its number of residents"@en .

### Territorial partition

mvdo:TerritorialPartition a owl:Class ;
    rdfs:label "Territorial Partition"@en ;
    rdfs:comment "A class used to describe the spatial granularity"@en .

mvdo:hasPartitionID a owl:DatatypeProperty ;
    rdfs:domain mvdo:TerritorialPartition ;
    rdfs:range rdfs:Literal ;
    rdfs:label "has partition id"@en ;
    rdfs:comment "Links a territorial partition to its ID"@en .

mvdo:hasParts a owl:DatatypeProperty ;
    rdfs:domain mvdo:TerritorialPartition ;
    rdfs:range xsd:integer ;
    rdfs:label "has parts"@en ;
    rdfs:comment "Links a territorial partition to the number of spatial location it contains"@en .